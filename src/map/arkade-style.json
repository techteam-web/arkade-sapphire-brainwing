{
  "version": 8,
  "name": "Arkade Sapphire — Night Baseline",
  "metadata": {
    "comment": "Authored as a base, night palette baked in as the static default for zero-flash first paint. Zoom-dependent paint expressions (road-width interpolations, extrusion-height ramps, etc.) live here — never in mapTheme.js. Refine visually in Maputnik later — keep layer IDs stable, mapTheme.js's THEMED_LAYER_IDS is the contract."
  },
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key={key}",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key={key}"
    }
  },
  "sprite": "",
  "layers": [
    {
      "id": "bg",
      "type": "background",
      "paint": {
        "background-color": "#3B2A22"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#2A1D17",
        "fill-opacity": 0.6,
        "fill-antialias": false
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "in",
        ["get", "class"],
        ["literal", ["residential", "commercial", "industrial", "military", "school", "hospital"]]
      ],
      "paint": {
        "fill-color": "#2A1D17",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#2A1D17",
        "fill-opacity": 0.75
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", ["get", "intermittent"], 1],
      "paint": {
        "fill-color": "#16294A",
        "fill-opacity": 1
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#16294A",
        "line-opacity": 1,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          10, 0.5,
          16, 2
        ]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#2A1D17",
        "fill-opacity": 0.85,
        "fill-outline-color": "#3B2A22"
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": [
        "in",
        ["get", "class"],
        ["literal", ["minor", "service", "track"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#8A8480",
        "line-opacity": 0.25,
        "line-width": [
          "interpolate", ["exponential", 1.2], ["zoom"],
          12, 0.25,
          18, 4
        ]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        ["get", "class"],
        ["literal", ["secondary", "tertiary"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#A85A33",
        "line-opacity": 0.75,
        "line-width": [
          "interpolate", ["exponential", 1.2], ["zoom"],
          8, 0.4,
          16, 5
        ]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "primary"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#C68A3A",
        "line-opacity": 0.85,
        "line-width": [
          "interpolate", ["exponential", 1.2], ["zoom"],
          7, 0.5,
          16, 6
        ]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        ["get", "class"],
        ["literal", ["motorway", "trunk"]]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#C68A3A",
        "line-opacity": 1,
        "line-width": [
          "interpolate", ["exponential", 1.4], ["zoom"],
          6, 0.5,
          16, 8
        ]
      }
    },
    {
      "id": "building-3d",
      "type": "fill-extrusion",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "filter": ["!=", ["get", "hide_3d"], true],
      "paint": {
        "fill-extrusion-color": "#2A1D17",
        "fill-extrusion-height": [
          "interpolate", ["linear"], ["zoom"],
          14, 0,
          14.5, ["coalesce", ["get", "render_height"], ["get", "height"], 10]
        ],
        "fill-extrusion-base": [
          "coalesce", ["get", "render_min_height"], ["get", "min_height"], 0
        ],
        "fill-extrusion-opacity": 0.9,
        "fill-extrusion-vertical-gradient": true
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["<=", ["get", "admin_level"], 6],
      "paint": {
        "line-color": "#8A8480",
        "line-opacity": 0.3,
        "line-width": 0.6,
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "label-road",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 13,
      "filter": [
        "in",
        ["get", "class"],
        ["literal", ["motorway", "trunk", "primary"]]
      ],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          13, 9,
          18, 12
        ],
        "text-letter-spacing": 0.08
      },
      "paint": {
        "text-color": "#8A8480",
        "text-halo-color": "#3B2A22",
        "text-halo-width": 1
      }
    },
    {
      "id": "label-place-minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 11,
      "filter": [
        "in",
        ["get", "class"],
        ["literal", ["suburb", "neighbourhood", "village", "town"]]
      ],
      "layout": {
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          11, 10,
          16, 13
        ],
        "text-letter-spacing": 0.12,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#8A8480",
        "text-halo-color": "#3B2A22",
        "text-halo-width": 1
      }
    },
    {
      "id": "label-place-major",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "in",
        ["get", "class"],
        ["literal", ["city", "state", "country"]]
      ],
      "layout": {
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          4, 11,
          12, 16
        ],
        "text-letter-spacing": 0.16,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#F4F1EB",
        "text-halo-color": "#3B2A22",
        "text-halo-width": 1
      }
    }
  ]
}
